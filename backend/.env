# ─────────────────────────────────────────────────────────────────
# CodeMind — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────

# ── Gemini API ───────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAgNzk6c_QInT7ZdjKvlH2vJwnh7n9r-pI
GEMINI_MODEL=gemini-3.1-flash-lite

# ── App Settings ─────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── OKF Bundle Storage ───────────────────────────────────────────
# Path where generated OKF bundles will be saved.
# Relative to the project root (F:\Data_Science_Project\OKF\)
OKF_BUNDLES_DIR=okf_bundles

# ── Git / Repo Settings ──────────────────────────────────────────
# Temp directory where repos are cloned before analysis
REPOS_CLONE_DIR=.tmp_repos

# Max repo size to analyze (in MB). Repos larger than this are rejected.
MAX_REPO_SIZE_MB=500

# ── Agent Settings ───────────────────────────────────────────────
# Max number of OKF files to inject into the LLM context per question
AGENT_MAX_CONTEXT_FILES=5

# Min relevance score (0.0–1.0) for a file to be included in context
AGENT_MIN_RELEVANCE_SCORE=0.1
